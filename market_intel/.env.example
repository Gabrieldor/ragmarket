# Copy to .env and adjust as needed.

# SQLite DB file path (relative to market_intel/ or absolute).
DATABASE_URL=sqlite:///./market_intel.db

# Collector polling cadence, in seconds. Time spent on cache-miss location
# lookups during a cycle is subtracted from this before sleeping (see
# ARCHITECTURE.md section 2).
POLL_INTERVAL_SECONDS=600

# Raw observation retention window, in days, before rollup + archival.
RAW_RETENTION_DAYS=30

# Reused from the existing scraper's config.json (server/store scope for v1).
SERVER_TYPE=FREYA
STORE_TYPE=BUY

# Browser behavior, mirrors config.json in the existing scraper.
HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# Throttling -- mirrors the original scraper's rule_delay. Inserted between each
# item's scrape, and between each location-modal click within an item, to avoid
# hammering the site and triggering HTTP 429s.
ITEM_DELAY_SECONDS=8.0
LOCATION_CLICK_DELAY_SECONDS=2.5
